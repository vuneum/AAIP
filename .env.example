# .env.example — commit this file, NEVER commit .env
AEP_RPC_URL=https://sepolia.base.org
AEP_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
AEP_CHAIN_ID=84532
AEP_ADAPTER=evm
POE_ANCHOR_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS
AEP_DB_PATH=~/.aaip-payments.db
AEP_BILLING_DB=~/.aaip-billing.db
AEP_ANCHOR_PATH=~/.aaip-anchors.json
AEP_PAYMENT_AMOUNT=0.0001
AEP_ETH_USD_RATE=3500
AEP_PROTOCOL_FEE_RATE=0.02
# REQUIRED when AEP_ADAPTER=evm — set to your protocol treasury wallet.
# Leaving this unset with AEP_ADAPTER=evm raises an error at startup.
AEP_TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_HERE