# AAIP — Autonomous Agent Identity Protocol
# Environment Configuration
# Copy to .env and fill in your values

# ── Database ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aaip:aaip_secret@db:5432/aaip

# ── Auth ────────────────────────────────────
# Set to "true" to skip auth in local development (never in production)
AAIP_DEV_MODE=false

# ── AI Judges (via OpenRouter) ───────────────
# Required for multi-model jury evaluation
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Embeddings ───────────────────────────────
# For semantic similarity search in retrieval
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use local embeddings instead (lighter, no API cost)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Celery / Redis (async job queue) ─────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0

# ── Payments (optional — Full integration) ────
# Set your default payout wallet per chain
AAIP_WALLET_BASE=0x0000000000000000000000000000000000000000
AAIP_WALLET_ETHEREUM=0x0000000000000000000000000000000000000000
AAIP_WALLET_TRON=T000000000000000000000000000000000
AAIP_WALLET_SOLANA=11111111111111111111111111111111

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
